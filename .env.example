# BlueFire-Nexus environment template (local-first baseline).
# Telemetry is local-only; no outbound SIEM exporter tokens belong here.

# Core runtime
LOG_LEVEL=
BLUEFIRE_KILLSWITCH=
BLUEFIRE_SAFEMODE=
ENCRYPT_KEY=

# Optional AI providers (only set if the AI/copilot feature is enabled).
# All providers are optional; the offline `template` provider is the default.
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
